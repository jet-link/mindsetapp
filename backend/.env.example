# Скопируйте в корень репозитория как .env и поправьте значения.

DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# 1 — работать на sqlite без Docker (только dev)
USE_SQLITE=0

# Postgres (совпадает с docker-compose.yml; порт 5433,
# т.к. на 5432 может жить локальный Homebrew Postgres)
POSTGRES_DB=mindset
POSTGRES_USER=mindset
POSTGRES_PASSWORD=mindset
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Redis (порт 6380, чтобы не конфликтовать с локальным redis)
REDIS_URL=redis://127.0.0.1:6380/0

# Search cache TTL (seconds)
SEARCH_DISCOVER_CACHE_TTL=900
SEARCH_TRENDING_CACHE_TTL=600
SEARCH_POPULAR_QUERIES_CACHE_TTL=300
SEARCH_EVENT_RETENTION_DAYS=90

# Prod-only
# DJANGO_ALLOWED_HOSTS=mindset.example.com
# CORS_ALLOWED_ORIGINS=https://mindset.example.com
# CSRF_TRUSTED_ORIGINS=https://mindset.example.com

# Social auth (allauth) — заполним при подключении Google/Apple
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_KEY_ID=
# APPLE_TEAM_ID=
